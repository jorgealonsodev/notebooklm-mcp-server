{
  "servers": {
    "notebooklm": {
      "type": "stdio",
      "command": "${workspaceFolder}/notebooklm-mcp-server",
      "args": [
        "--transport=stdio"
      ],
      "env": {
        "HEADLESS": "false",
        "STEALTH_ENABLED": "true",
        "ANSWER_TIMEOUT_MS": "300000"
      }
    }
  }
}
